}


/* ComboBox scroll bar styling */
QComboBox QAbstractItemView {
    background-color: #f4f4f4; /* popup background */
    selection-background-color: #a0c4ff; /* item hover/select */
    outline: 0;
}

QComboBox QScrollBar:vertical {
    border: none;
    background: #e0e0e0; /* track color */
    width: 12px;
    margin: 0px 0px 0px 0px;
    border-radius: 6px;
}

QComboBox QScrollBar::handle:vertical {
    background: #7a8c99; /* scroll handle color */
    min-height: 20px;
    border-radius: 6px;
}

QComboBox QScrollBar::add-line:vertical,
QComboBox QScrollBar::sub-line:vertical {
    height: 0px; /* remove arrow buttons */
}

QComboBox QScrollBar::add-page:vertical,
QComboBox QScrollBar::sub-page:vertical {
    background: none;
}
QComboBox:focus{
border: 1px solid #4a90e2;
}

